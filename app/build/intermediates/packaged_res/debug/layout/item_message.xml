<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <!-- User Message (Right aligned) -->
    <LinearLayout
        android:id="@+id/user_message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_user_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="User message"
            android:textColor="@color/message_user_text"
            android:textSize="15sp"
            android:background="@drawable/bg_message_user" />

    </LinearLayout>

    <!-- Assistant Message (Left aligned) -->
    <LinearLayout
        android:id="@+id/assistant_message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="280dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_assistant_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Assistant message"
            android:textColor="@color/message_assistant_text"
            android:textSize="15sp"
            android:background="@drawable/bg_message_assistant" />

    </LinearLayout>

</FrameLayout>
